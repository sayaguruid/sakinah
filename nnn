    if(currentUser.foto)av.innerHTML='<img src="'+getPhotoUrl(currentUser.foto)+'" loading="lazy">';else av.textContent=getInitials(currentUser.nama);
    if(adminRoles.indexOf(currentUser.role)!==-1){
        document.getElementById('nav-personal').classList.add('hidden');document.getElementById('nav-admin').classList.remove('hidden');
        document.getElementById('adminRoleLabel').textContent=currentUser.role;document.getElementById('adminScopeLabel').textContent=currentUser.scope||'All';
