    var escaped=text.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/'/g,'&#39;');
    var svg='<svg xmlns="http://www.w3.org/2000/svg" width="300" height="180"><text x="150" y="90" transform="rotate(-28 150 90)" font-size="11" fill="rgba(255,255,255,0.04)" font-family="Arial,sans-serif" text-anchor="middle" font-weight="bold">'+escaped+'</text></svg>';
    return 'url("data:image/svg+xml,'+encodeURIComponent(svg)+'")';
}
function showWatermark(){
    if(!currentUser)return;
    var wm=document.getElementById('watermark-layer');
    if(!wm){wm=document.createElement('div');wm.id='watermark-layer';document.body.appendChild(wm)}
