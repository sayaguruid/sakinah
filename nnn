async function requestTaaruf(email,nama,daerah){
    showLoading();
    var res=await fetchGAS('requestTaaruf',{},'POST',{pelamarEmail:currentUser.email,targetEmail:email});
    hideLoading();
    if(res.status==='success'){
        if(res.waNumber&&res.waNumber.length>5){
            var pesan="Assalamu'alaikum, saya "+currentUser.nama+" dari kelompok "+(currentUser.kelompok||'-')+". Saya ingin mengajukan ta'aruf dengan "+nama+" ("+(daerah||'-')+") melalui Halalkan. Mohon bimbingannya.";
            var waUrl="https://wa.me/"+res.waNumber+"?text="+encodeURIComponent(pesan);
            var box=document.getElementById('search-taaruf-blocked');box.classList.remove('hidden');
            box.innerHTML='<div class="wa-info-box"><div class="wa-title"><i class="fab fa-whatsapp" style="color:#6EE7B7;font-size:1.1rem"></i> Tim Pernikahan '+esc(daerah)+'</div><div class="wa-detail"><b>'+esc(res.teamName)+'</b>'+(res.teamPeran?' ('+esc(res.teamPeran)+')':'')+'<br>Nomor: '+res.waNumber+'</div><div class="wa-btn"><a href="'+waUrl+'" target="_blank" rel="noopener" class="btn btn-sm btn-wa" style="width:auto;display:inline-flex"><i class="fab fa-whatsapp"></i> Chat WhatsApp Sekarang</a></div></div>';
            showToast('Pengajuan dicatat! Hubungi tim pernikahan via WhatsApp.');
            window.open(waUrl,'_blank');
        }else{showToast('Pengajuan terkirim! Namun belum ada tim pernikahan untuk daerah ini.','error')}
        searchIamInTaaruf=true;hideWatermark();renderCards(allUsers);refreshNotifCount();
    }else{showToast(res.message||'Gagal mengajukan','error')}
}

/* ===== STATUS TAARUF ===== */
async function loadMyTaarufStatus(){
    var el=document.getElementById('status-content');el.innerHTML='<div class="empty-state"><i class="fas fa-spinner fa-spin"></i><p>Memuat status...</p></div>';
    var res=await fetchGAS('getMyTaaruf',{email:currentUser.email});
    if(res.status!=='success'){el.innerHTML='<div class="empty-state"><i class="fas fa-exclamation-triangle" style="color:var(--gold-400)"></i><p>Gagal memuat status.</p><button class="btn btn-sm retry-btn" onclick="loadMyTaarufStatus()"><i class="fas fa-redo"></i> Coba Lagi</button></div>';return}
    if(res.data&&res.data.length>0){
        var statusDesc={'Pending':'Menunggu konfirmasi tim pernikahan.','Sedang Taaruf':'Sedang dalam proses ta\'aruf.','Sedang Proses':'Proses ta\'aruf sedang berlanjut.','Sudah Menikah':'Alhamdulillah, proses telah selesai.','Rejected':'Pengajuan ditolak. Anda dapat kembali melihat daftar peserta di menu Temukan Pasangan.'};
        el.innerHTML=res.data.map(function(r){
            var bc='badge-pending';if(r.status==='Sedang Taaruf')bc='badge-taaruf';else if(r.status==='Sedang Proses')bc='badge-proses';else if(r.status==='Sudah Menikah')bc='badge-menikah';else if(r.status==='Rejected')bc='badge-rejected';
            var roleText=r.isPelamar?'Anda mengajukan':'Mengajukan Anda';
            return '<div class="status-card"><div class="status-card-header"><div class="status-card-title">'+esc(r.otherNama)+'</div><span class="badge '+bc+'">'+r.status+'</span></div><div class="status-card-meta"><i class="fas fa-info-circle"></i> '+roleText+'<br><i class="fas fa-calendar"></i> '+r.tanggal+'<br><i class="fas fa-map-marker-alt"></i> '+esc(r.otherDaerah)+', '+esc(r.otherDesa)+'<br><i class="fas fa-users"></i> Kelompok target: '+esc(r.otherKelompok)+'<br><i class="fas fa-user-tag"></i> Kelompok Anda: '+esc(r.myKelompok)+'<br><div style="margin-top:6px;color:'+(r.status==='Rejected'?'#FCA5A5':'var(--green-400)')+';font-weight:600;font-size:0.8rem">'+(statusDesc[r.status]||'')+'</div></div></div>'
        }).join('');
    }else{el.innerHTML='<div class="empty-state"><i class="fas fa-heart"></i><p>Belum ada pengajuan ta\'aruf.</p></div>'}
}

/* ===== KEGIATAN ===== */
async function loadKegiatanCache(){try{var res=await fetchGAS('getKegiatan');if(res.status==='success')cachedKegiatan=res.data||[]}catch(e){}}
function renderKegiatanCards(data){
    if(!data||data.length===0)return '<div class="empty-state"><i class="fas fa-bullhorn"></i><p>Belum ada informasi kegiatan.</p></div>';
    return data.map(function(k){
        var imgHtml=k.foto?'<img src="'+getPhotoUrl(k.foto)+'" loading="lazy" decoding="async" onclick="openPhotoModal(\''+getPhotoUrl(k.foto)+'\')" alt="Foto Kegiatan">':'';
        return '<div class="kegiatan-card">'+imgHtml+'<div class="kegiatan-card-body"><div class="kegiatan-card-title">'+esc(k.judul)+'</div><div class="kegiatan-card-content">'+esc(k.isi)+'</div></div><div class="kegiatan-card-footer"><span><i class="far fa-clock"></i> '+k.tanggal+'</span><span><i class="far fa-user"></i> '+esc(k.postedBy)+'</span></div></div>'
    }).join('');
}
async function loadKegiatanPage(){var el=document.getElementById('kegiatan-list');el.innerHTML='<div class="empty-state"><i class="fas fa-spinner fa-spin"></i><p>Memuat kegiatan...</p></div>';await loadKegiatanCache();el.innerHTML=renderKegiatanCards(cachedKegiatan)}
async function loadAdminKegiatan(){var el=document.getElementById('admin-kegiatan-list');el.innerHTML='<div class="empty-state"><i class="fas fa-spinner fa-spin"></i><p>Memuat...</p></div>';await loadKegiatanCache();el.innerHTML=renderKegiatanCards(cachedKegiatan)}
async function handleAddKegiatan(e){
    e.preventDefault();var btn=document.getElementById('btnAddKg');btn.disabled=true;btn.innerHTML='<i class="fas fa-spinner fa-spin"></i> Publikasi...';
    var fotoBase64=null;var fotoInput=document.getElementById('kgFoto');
    if(fotoInput&&fotoInput.files&&fotoInput.files[0]){
        if(fotoInput.files[0].size>3*1024*1024){showToast('Ukuran foto maks 3MB','error');btn.disabled=false;btn.innerHTML='<i class="fas fa-paper-plane"></i> Publikasikan';return}
        try{fotoBase64=await compressImage(fotoInput.files[0],800,0.75)}catch(err){showToast('Gagal proses foto','error');btn.disabled=false;btn.innerHTML='<i class="fas fa-paper-plane"></i> Publikasikan';return}
    }
    var res=await fetchGAS('addKegiatan',{},'POST',{judul:document.getElementById('kgJudul').value.trim(),isi:document.getElementById('kgIsi').value.trim(),foto:fotoBase64,postedBy:currentUser.nama});
    if(res.status==='success'){showToast(res.message);document.getElementById('kegiatanForm').reset();document.getElementById('kgFotoPreview').style.display='none';cachedKegiatan=[];loadAdminKegiatan()}
    else{showToast(res.message||'Gagal mempublikasikan','error')}
    btn.disabled=false;btn.innerHTML='<i class="fas fa-paper-plane"></i> Publikasikan';
}

/* ===== ADMIN DATA PESERTA — DENGAN FOTO ===== */
async function loadAdminUsers(){
    var t=document.getElementById('admin-tbody'),pg=document.getElementById('admin-users-pagination');
    t.innerHTML='<tr><td colspan="5" style="text-align:center"><i class="fas fa-spinner fa-spin"></i></td></tr>';pg.innerHTML='';adminCurrentPage=1;
    var res=await fetchGAS('getUsers',{role:currentUser.role,email:currentUser.email,scope:currentUser.scope});
    if(res.status==='error'){t.innerHTML='<tr><td colspan="5" style="text-align:center"><i class="fas fa-exclamation-triangle" style="color:var(--gold-400);margin-right:8px"></i>Gagal memuat data. <a class="link" onclick="loadAdminUsers()">Coba Lagi</a></td></tr>';return}
    if(res.status==='success'&&res.data&&res.data.length>0){
        allUsers=res.data;
        /* Bangun map foto untuk digunakan di tabel taaruf */
        userPhotoMap={};
        allUsers.forEach(function(u){if(u.foto&&u.email)userPhotoMap[u.email]=getPhotoUrl(u.foto)});
        renderAdminUsers(allUsers);
    }else{allUsers=[];userPhotoMap={};t.innerHTML='<tr><td colspan="5" style="text-align:center;color:var(--text-muted-light)">Tidak ada data.</td></tr>'}
}
function renderAdminUsers(users){
    var t=document.getElementById('admin-tbody'),pg=document.getElementById('admin-users-pagination');
    var s=(document.getElementById('adminSearchInput')?document.getElementById('adminSearchInput').value:'').toLowerCase();
    var filtered=users.filter(function(u){return !s||(u.nama&&u.nama.toLowerCase().indexOf(s)!==-1)});
    var totalPages=Math.max(1,Math.ceil(filtered.length/adminPageSize));
    if(adminCurrentPage>totalPages)adminCurrentPage=totalPages;
    var start=(adminCurrentPage-1)*adminPageSize,pageItems=filtered.slice(start,start+adminPageSize);
    if(filtered.length===0){t.innerHTML='<tr><td colspan="5" style="text-align:center;color:var(--text-muted-light)">Tidak ditemukan.</td></tr>';pg.innerHTML='';return}
    t.innerHTML=pageItems.map(function(u){
        var sc=u.isComplete?'badge-approved':'badge-pending';var st=u.isComplete?'Lengkap':'Belum';
        var ps=u.foto?getPhotoUrl(u.foto):'';
        var kr=u.kriteriaPasangan?'<div class="data-cell-line" style="margin-top:3px"><b style="color:var(--gold-400)">Kriteria:</b> <span style="font-size:0.74rem;color:var(--text-muted-light)">'+esc(u.kriteriaPasangan).substring(0,70)+(u.kriteriaPasangan.length>70?'...':'')+'</span></div>':'';
        /* Foto admin dengan klik untuk modal */
        var photoBlock;
        if(ps){
            photoBlock='<div class="admin-photo-cell"><img src="'+ps+'" class="admin-photo" loading="lazy" decoding="async" onclick="openPhotoModal(\''+ps+'\')" title="Klik untuk memperbesar"></div>';
        }else{
            photoBlock='<div class="admin-photo-cell"><div class="admin-photo-placeholder">'+getInitials(u.nama)+'</div></div>';
        }
        return '<tr><td><div style="display:flex;align-items:center;gap:10px">'+photoBlock+'<div><div style="font-weight:700;color:var(--text-white)">'+esc(u.nama)+'</div><div class="sub-text">'+esc(u.email)+'</div><div style="margin-top:2px"><span class="badge '+(u.gender==='Perempuan'?'badge-f':'badge-m')+'">'+esc(u.gender||'-')+'</span></div></div></div></td><td><div class="data-cell-line"><b>Ortu:</b> '+esc(u.namaOrtu)+'</div><div class="data-cell-line"><b>TTL:</b> '+esc(u.ttl)+'</div><div class="data-cell-line"><b>Anak ke:</b> '+esc(u.anakKe)+'</div><div class="data-cell-line"><b>Suku:</b> '+esc(u.suku)+' | <b>TB/BB:</b> '+esc(u.tbBerat)+'</div><div class="data-cell-line"><b>Status:</b> '+esc(u.menikah)+'</div></td><td><div class="data-cell-line"><b>Pendidikan:</b> '+esc(u.pendidikan)+'</div><div class="data-cell-line"><b>Pekerjaan:</b> '+esc(u.pekerjaan)+'</div><div class="data-cell-line"><b>Hobi:</b> '+esc(u.hobi)+'</div><div class="data-cell-line"><b>Dapukan:</b> '+esc(u.dapukan)+'</div>'+kr+'</td><td><div class="data-cell-line">'+esc(u.daerah)+'</div><div class="data-cell-line">'+esc(u.desa)+'</div><div class="data-cell-line">'+esc(u.kelompok)+'</div></td><td><span class="badge '+sc+'">'+st+'</span></td></tr>'
    }).join('');
    generatePagination('admin-users-pagination',adminCurrentPage,totalPages,filtered.length,adminPageSize,'goToAdminPage');
}
function filterAdmin(){adminCurrentPage=1;renderAdminUsers(allUsers)}

/* ===== ADMIN TAARUF — DENGAN FOTO PELAMAR & TARGET ===== */
async function loadAdminTaaruf(){
    var t=document.getElementById('admin-taaruf-tbody');
    t.innerHTML='<tr><td colspan="5" style="text-align:center"><i class="fas fa-spinner fa-spin"></i></td></tr>';
    /* Pastikan foto map sudah terisi, kalau belum muat data peserta dulu */
    if(Object.keys(userPhotoMap).length===0){
        try{
            var usersRes=await fetchGAS('getUsers',{role:currentUser.role,email:currentUser.email,scope:currentUser.scope});
            if(usersRes.status==='success'&&usersRes.data){
                userPhotoMap={};
                usersRes.data.forEach(function(u){if(u.foto&&u.email)userPhotoMap[u.email]=getPhotoUrl(u.foto)});
            }
        }catch(e){}
    }
    var res=await fetchGAS('getAllTaaruf',{role:currentUser.role,email:currentUser.email,scope:currentUser.scope});
    if(res.status!=='success'){t.innerHTML='<tr><td colspan="5" style="text-align:center"><i class="fas fa-exclamation-triangle" style="color:var(--gold-400);margin-right:8px"></i>Gagal memuat. <a class="link" onclick="loadAdminTaaruf()">Coba Lagi</a></td></tr>';return}
    if(res.data&&res.data.length>0){allTaarufRequests=res.data;renderAdminTaaruf(allTaarufRequests)}
    else{allTaarufRequests=[];t.innerHTML='<tr><td colspan="5" style="text-align:center;color:var(--text-muted-light)">Belum ada pengajuan.</td></tr>'}
}
function filterTaaruf(btn,filter){currentTaarufFilter=filter;document.querySelectorAll('#taarufFilterTabs .filter-tab').forEach(function(b){b.classList.remove('active')});btn.classList.add('active');renderAdminTaaruf(allTaarufRequests)}
function getBadgeClass(status){var m={'Pending':'badge-pending','Sedang Taaruf':'badge-taaruf','Sedang Proses':'badge-proses','Sudah Menikah':'badge-menikah','Rejected':'badge-rejected','Approved':'badge-approved'};return m[status]||'badge-pending'}
function getActionButtons(status,pEmail,tEmail){
    if(status==='Pending')return '<div class="action-btns"><button class="btn btn-sm btn-info-sm" onclick="updateTaarufStatus(\''+pEmail+'\',\''+tEmail+'\',\'Sedang Taaruf\')"><i class="fas fa-heart"></i> Taaruf</button><button class="btn btn-sm btn-danger-sm" onclick="updateTaarufStatus(\''+pEmail+'\',\''+tEmail+'\',\'Rejected\')"><i class="fas fa-times"></i> Tolak</button></div>';
    if(status==='Sedang Taaruf')return '<div class="action-btns"><button class="btn btn-sm btn-warning-sm" onclick="updateTaarufStatus(\''+pEmail+'\',\''+tEmail+'\',\'Sedang Proses\')"><i class="fas fa-spinner"></i> Proses</button><button class="btn btn-sm btn-danger-sm" onclick="updateTaarufStatus(\''+pEmail+'\',\''+tEmail+'\',\'Rejected\')"><i class="fas fa-times"></i> Tolak</button></div>';
    if(status==='Sedang Proses')return '<div class="action-btns"><button class="btn btn-sm btn-success" onclick="updateTaarufStatus(\''+pEmail+'\',\''+tEmail+'\',\'Sudah Menikah\')"><i class="fas fa-ring"></i> Menikah</button><button class="btn btn-sm btn-danger-sm" onclick="updateTaarufStatus(\''+pEmail+'\',\''+tEmail+'\',\'Rejected\')"><i class="fas fa-times"></i> Tolak</button></div>';
    if(status==='Sudah Menikah')return '<span style="font-size:0.78rem;color:var(--green-400);font-weight:700"><i class="fas fa-check-circle"></i> Selesai</span>';
    if(status==='Rejected')return '<span style="font-size:0.78rem;color:#FCA5A5;font-weight:500">Ditolak</span>';
    return '-'
}

/* Fungsi helper: buat HTML sel foto untuk tabel taaruf */
function buildTaarufPhotoCell(email, nama){
    var ps=userPhotoMap[email]||'';
    if(ps){
        return '<div class="admin-photo-cell" style="margin-bottom:4px"><img src="'+ps+'" class="admin-photo admin-photo-sm" loading="lazy" decoding="async" onclick="openPhotoModal(\''+ps+'\')" title="Klik untuk memperbesar"></div>';
    }
    return '<div class="admin-photo-cell" style="margin-bottom:4px"><div class="admin-photo-placeholder admin-photo-placeholder-sm">'+getInitials(nama)+'</div></div>';
}

function renderAdminTaaruf(requests){
    var t=document.getElementById('admin-taaruf-tbody');
    var f=currentTaarufFilter?requests.filter(function(r){return r.status===currentTaarufFilter}):requests;
    if(f.length===0){t.innerHTML='<tr><td colspan="5" style="text-align:center;color:var(--text-muted-light)">Tidak ada data untuk filter ini.</td></tr>';return}
    t.innerHTML=f.map(function(r){
        /* FOTO PELAMAR & TARGET ditampilkan di kolom masing-masing */
        var pelamarPhoto=buildTaarufPhotoCell(r.pelamarEmail,r.pelamarNama);
        var targetPhoto=buildTaarufPhotoCell(r.targetEmail,r.targetNama);

        return '<tr><td style="white-space:nowrap">'+r.tanggal+'</td><td>'+pelamarPhoto+'<b style="color:var(--text-white)">'+esc(r.pelamarNama)+'</b><div class="sub-text">'+esc(r.pelamarEmail)+'</div><div class="sub-text" style="color:var(--green-400)">'+esc(r.pelamarDaerah)+', '+esc(r.pelamarDesa)+'</div><div class="sub-text"><i class="fas fa-users" style="width:12px"></i> '+esc(r.pelamarKelompok)+'</div></td><td>'+targetPhoto+'<b style="color:var(--text-white)">'+esc(r.targetNama)+'</b><div class="sub-text">'+esc(r.targetEmail)+'</div><div class="sub-text" style="color:var(--green-400)">'+esc(r.targetDaerah)+', '+esc(r.targetDesa)+'</div><div class="sub-text"><i class="fas fa-users" style="width:12px"></i> '+esc(r.targetKelompok)+'</div></td><td><span class="badge '+getBadgeClass(r.status)+'">'+r.status+'</span></td><td>'+getActionButtons(r.status,r.pelamarEmail,r.targetEmail)+'</td></tr>'
    }).join('');
}

async function updateTaarufStatus(pEmail,tEmail,newStatus){
    if(!confirm('Ubah status menjadi "'+newStatus+'"?'))return;
    showLoading();
    var res=await fetchGAS('updateTaarufStatus',{},'POST',{pelamarEmail:pEmail,targetEmail:tEmail,newStatus:newStatus});
    hideLoading();
    if(res.status==='success'){showToast(res.message);loadAdminTaaruf();refreshNotifCount()}
    else{showToast(res.message||'Gagal update','error')}
}
</script>
</body>
