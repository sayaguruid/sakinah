var FETCH_TIMEOUT=30000,currentUser=null,masterData={daerah:[],desa:{},kelompok:{}},allUsers=[],allTaarufRequests=[],currentTaarufFilter='',cachedTaarufTim={},cachedKegiatan=[],adminRoles=['Admin','Desa','Daerah','Super Admin'];
